          "$value": "{text.font-size.base} * 1.5"
        },
        "3xl": {
          "$type": "fontSizes",
          "$value": "{text.font-size.base} * 2"
        },
        "4xl": {
          "$type": "fontSizes",
          "$value": "{text.font-size.base} * 2.5"
        }
      },
      "line-height": {
        "sm": {
          "$type": "lineHeights",
          "$value": "150%"
        },
        "md": {
          "$type": "lineHeights",
          "$value": "150%"
        },
        "lg": {
          "$type": "lineHeights",
          "$value": "125%"
