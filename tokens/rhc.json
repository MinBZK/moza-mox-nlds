    "text": {
      "font-family": {
        "default": {
          "$type": "fontFamilies",
          "$value": "RijksSansVF",
          "$description": "Rijksoverheid Sans variable font"
        }
      },
      "weight": {
        "default": {
          "$type": "fontWeights",
          "$value": "Regular"
        },
        "semibold": {
          "$type": "fontWeights",
          "$value": "SemiBold"
        },
        "bold": {
          "$type": "fontWeights",
          "$value": "Bold"
        }
      },
      "font-size": {
        "base": {
          "$type": "fontSizes",
          "$value": "16",
          "$description": "Modifier voor de schaal van overige groottes."
        },
        "2xs": {
          "$type": "fontSizes",
          "$value": "{text.font-size.base} / 1.5"
        },
        "xs": {
          "$type": "fontSizes",
          "$value": "{text.font-size.base} / 1.25"
        },
        "sm": {
          "$type": "fontSizes",
          "$value": "{text.font-size.base} / 1.125"
        },
        "md": {
          "$type": "fontSizes",
          "$value": "{text.font-size.base}"
        },
        "lg": {
          "$type": "fontSizes",
          "$value": "{text.font-size.base} * 1.125"
        },
        "xl": {
          "$type": "fontSizes",
          "$value": "{text.font-size.base} * 1.25"
