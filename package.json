{
  "name": "mox-nlds",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    "./react": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./css": "./dist/moxCss/index.css",
    "./tokens": "./dist/moxCss/tokens/"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project=unit",
    "generate:css": "tsx src/moxCss/generateCss.ts",
    "dev:storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "deploy": "npm run generate:css && npm run build:storybook && gh-pages -d storybook-static",
    "build:tokens": "node tokens/build.mjs",
    "build:css": "npm run generate:css && cp -R src/moxCss dist/",
    "build:react": "tsc --project tsconfig.json",
    "build": "rm -rf ./dist && npm run build:tokens && npm run build:react && npm run build:css",
    "prepare": "npm run build"
  },
  "homepage": "https://minbzk.github.io/moza-mox-nlds/",
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "bootstrap-icons": "^1.13.1",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/js": "^9.39.1",
    "@storybook/addon-a11y": "^10.1.4",
    "@storybook/addon-docs": "^10.1.4",
    "@storybook/addon-vitest": "^10.1.4",
    "@storybook/react-vite": "^10.2.16",
    "@tokens-studio/sd-transforms": "^2.0.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.1.4",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "playwright": "^1.57.0",
    "prettier": "^3.8.1",
    "storybook": "^10.1.4",
    "style-dictionary": "^5.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  }
}
