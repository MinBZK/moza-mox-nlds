{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "jsx": "react-jsx",
    "module": "CommonJS",
    "target": "ES2019",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "**/*.stories.tsx",
    "**/*.test.tsx",
    "**/*.test.ts",
    "node_modules",
    "dist",
    "src/main.tsx",
    "src/App.tsx",
    "src/moxCss/generateCss.ts",
    "src/storybook/**/*"
  ]
}
